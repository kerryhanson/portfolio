# Set to false to hide the Config menu (theme picker, hero visual, Workshop) in the global nav.
# VITE_SHOW_CONFIG_MENU=false

# Default home hero visual: profile | image | none
# VITE_HERO_VISUAL_MODE=profile

# Site access gate (client-side — soft barrier only). Enabled by default.
# VITE_SITE_ACCESS=false
# VITE_SITE_PASSWORD=Summer2026
